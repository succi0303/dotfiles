"3.8.1 (created: 2013/11/21 23:49:14)

source! /Users/succi0303/.vimperatorrc.local

" vim: set ft=vimperator:

" タイトル文字
set titlestring="Firefox"

" 検索結果をハイライト
set hlsearch

" リンクURLをコマンドラインに表示
set showstatuslinks=2

set complete=tl

" input要素にカーソルを取られない
set focuscontent

" 検索の大文字小文字を無視
set ignorecase

" GUI要素の表示・非表示
set gui=noaddons,nobookmarks,menu,navigation,notabs
set noscrollbars

" カラースキーマ
colorscheme vimpwhite

" カーソルキーで補完を選択
cnoremap <Up> <S-Tab>
cnoremap <Down> <Tab>

